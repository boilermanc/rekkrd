# ──────────────────────────────────────────────────────────────────────
# Sellr — required env vars
# Copy relevant vars to your .env and set real values.
# Vars marked "shared" are used by both Rekkrd and Sellr.
# ──────────────────────────────────────────────────────────────────────

# ── Stripe (shared — single Stripe account for subscriptions + Sellr) ──
STRIPE_SECRET_KEY=sk_live_...
STRIPE_SELLR_WEBHOOK_SECRET=whsec_...
# Frontend (Vite — prefix required)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── Sellr admin panel protection ──────────────────────────────────────
SELLR_ADMIN_TOKEN=generate-a-long-random-string
# Frontend mirror (same value as above)
VITE_SELLR_ADMIN_TOKEN=same-as-SELLR_ADMIN_TOKEN

# ── Email (Resend) ────────────────────────────────────────────────────
RESEND_API_KEY=re_...
ADMIN_EMAIL=you@rekkrd.com

# ── URLs ──────────────────────────────────────────────────────────────
BASE_URL=https://rekkrd.com

# ── Shared infrastructure (already set for Rekkrd — listed for reference) ──
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# GEMINI_API_KEY=AI...
# DISCOGS_PERSONAL_TOKEN=...
